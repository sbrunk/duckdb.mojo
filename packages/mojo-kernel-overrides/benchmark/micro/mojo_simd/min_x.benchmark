# name: benchmark/micro/mojo_simd/min_x.benchmark
# description: ungrouped aggregate — MIN(x)
# group: [mojo_simd]

name MIN(x)
group micro
subgroup mojo_simd

load
CREATE TABLE t AS SELECT ((i % 1000) + 1)::DOUBLE AS x, (((i*7) % 1000) + 1)::DOUBLE AS y FROM range(50000000) tbl(i);

run
SELECT MIN(x) FROM t;
