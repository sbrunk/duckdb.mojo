# name: benchmark/micro/mojo_simd/cos.benchmark
# description: Mojo SIMD patch target — cos(x)
# group: [mojo_simd]

name cos(x)
group micro
subgroup mojo_simd

load
CREATE TABLE t AS SELECT ((i % 1000) + 1)::DOUBLE AS x, (((i*7) % 1000) + 1)::DOUBLE AS y FROM range(50000000) tbl(i);

run
SELECT SUM(cos(x)) FROM t;
