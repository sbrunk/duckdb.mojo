# name: benchmark/micro/mojo_simd/sum_x.benchmark
# description: ungrouped aggregate — SUM(x)
# group: [mojo_simd]

name SUM(x)
group micro
subgroup mojo_simd

load
CREATE TABLE t AS SELECT ((i % 1000) + 1)::DOUBLE AS x, (((i*7) % 1000) + 1)::DOUBLE AS y FROM range(50000000) tbl(i);

run
SELECT SUM(x) FROM t;
