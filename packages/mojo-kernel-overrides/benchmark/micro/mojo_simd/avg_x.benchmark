# name: benchmark/micro/mojo_simd/avg_x.benchmark
# description: ungrouped aggregate — AVG(x)
# group: [mojo_simd]

name AVG(x)
group micro
subgroup mojo_simd

load
CREATE TABLE t AS SELECT ((i % 1000) + 1)::DOUBLE AS x, (((i*7) % 1000) + 1)::DOUBLE AS y FROM range(50000000) tbl(i);

run
SELECT AVG(x) FROM t;
