# name: benchmark/micro/mojo_simd/sin_of_cos.benchmark
# description: Mojo SIMD patch target — sin(cos(x))
# group: [mojo_simd]

name sin(cos(x))
group micro
subgroup mojo_simd

load
CREATE TABLE t AS SELECT ((i % 1000) + 1)::DOUBLE AS x, (((i*7) % 1000) + 1)::DOUBLE AS y FROM range(50000000) tbl(i);

run
SELECT SUM(sin(cos(x))) FROM t;
